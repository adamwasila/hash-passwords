{
  "manifest_version": 3,
  "name": "Hash Passwords",
  "version": "0.1.0",
  "description": "Firefox extension inspired by Stanford PwdHash to generate passwords.",
  "permissions": [
    "tabs",
    "storage"
  ],
  "action": {
    "default_title": "Hash Passwords",
    "default_popup": "popup.html"
  },
  "icons": {
    "48": "icons/icon-48.svg",
    "96": "icons/icon-96.svg"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "hash-passwords@wasila.org",
      "strict_min_version": "109.0"
    }
  }
}
